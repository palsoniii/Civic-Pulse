{
  "name": "@civicpulse/user-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run prisma:generate && node ../../node_modules/typescript/bin/tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "lint": "npm run prisma:generate && node ../../node_modules/typescript/bin/tsc --noEmit",
    "test": "echo 'no tests yet'",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@civicpulse/shared-middleware": "*",
    "@civicpulse/shared-redis": "*",
    "@civicpulse/shared-types": "*",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.4.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "winston": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
