# ─────────────────────────────────────────────────────────────
# CivicPulse — Root Environment Variables
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Shared Postgres credentials ──────────────────────────────
POSTGRES_USER=civicpulse
POSTGRES_PASSWORD=change_me_in_production

# ── Per-service database URLs ────────────────────────────────
DATABASE_URL_USERS=postgresql://civicpulse:change_me_in_production@localhost:5433/users_db
DATABASE_URL_COMPLAINTS=postgresql://civicpulse:change_me_in_production@localhost:5434/complaints_db
DATABASE_URL_ADMIN=postgresql://civicpulse:change_me_in_production@localhost:5435/admin_db
DATABASE_URL_NOTIFICATIONS=postgresql://civicpulse:change_me_in_production@localhost:5436/notifications_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO / S3 ───────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=civicpulse-media

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_in_production_use_long_random_string
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Service ports ────────────────────────────────────────────
GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
COMPLAINT_SERVICE_PORT=3002
ADMIN_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
MEDIA_SERVICE_PORT=3005

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# ── Email / SMS (notification-service) ──────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=change_me
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=change_me
TWILIO_FROM_NUMBER=+10000000000
